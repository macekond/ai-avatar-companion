# Copy this file to .env and fill in values you need.
# .env is gitignored — never commit real keys.

# ElevenLabs API key — only needed if privacy.allow_cloud_fallback: true in config.yaml
# ELEVENLABS_API_KEY=your_key_here

# Cloud LLM fallback (GPT-4o-mini) — only if privacy.allow_cloud_fallback: true
# OPENAI_API_KEY=your_key_here
